<Window x:Class="CtrlWiz.NW.UI.Views.HelpView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CtrlWiz.NW.UI.Views"
        xmlns:model="clr-namespace:CtrlWiz.NW.UI.ViewModels"
        mc:Ignorable="d"
        ResizeMode="NoResize"
        Topmost="True"
        WindowStartupLocation="CenterScreen"
        Icon="/CtrlWizNW.UI;component/Images/CtrlWizLogo.png"
        Title="Controller Map" Height="525" Width="775">
    <Window.Background>
        <ImageBrush>
            <ImageBrush.ImageSource>
                <BitmapImage UriSource="/CtrlWizNW.UI;component/Images/ControllerMap.png" />
            </ImageBrush.ImageSource>
        </ImageBrush>
    </Window.Background>

    <Window.DataContext>
        <model:HelpViewModel />
    </Window.DataContext>

    <Window.Resources>
        <Style x:Key="DisabledComboboxItemTextBlock" TargetType="{x:Type TextBlock}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType={x:Type ComboBox}},
                    Path=IsEnabled}" Value="False">
                    <Setter Property="Foreground" Value="#FFC5C5C5" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    
    <Grid>
        <!--Buttons-->
        <ComboBox x:Name="RBumberComboBox" Width="140" HorizontalAlignment="Right" VerticalAlignment="Top"  Margin="0,135,20,0"
            ItemsSource="{Binding ControllerButtonOptions}" SelectedIndex="{Binding SelectedRBumberIndex, Mode=TwoWay}">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding FunctionName}" TextTrimming="CharacterEllipsis" />
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>
        <ComboBox x:Name="XButtonComboBox" Width="140" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,313,20,0"
                  ItemsSource="{Binding ControllerButtonOptions}" SelectedIndex="{Binding SelectedXButtonIndex, Mode=TwoWay}">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding FunctionName}" TextTrimming="CharacterEllipsis" />
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>
        <ComboBox x:Name="YButtonComboBox" Width="140" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,171,20,0"
                  ItemsSource="{Binding ControllerButtonOptions}" SelectedIndex="{Binding SelectedYButtonIndex, Mode=TwoWay}">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding FunctionName}" TextTrimming="CharacterEllipsis" />
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>
        <ComboBox x:Name="AButtonComboBox" Width="140" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,262,20,0"
                  ItemsSource="{Binding ControllerButtonOptions}" SelectedIndex="{Binding SelectedAButtonIndex, Mode=TwoWay}">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding FunctionName}" TextTrimming="CharacterEllipsis" />
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>
        <ComboBox x:Name="BButtonComboBox" Width="140" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,217,20,0"
                  ItemsSource="{Binding ControllerButtonOptions}" SelectedIndex="{Binding SelectedBButtonIndex, Mode=TwoWay}">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding FunctionName}" TextTrimming="CharacterEllipsis" />
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>
        <ComboBox x:Name="StartButtonComboBox" Width="120" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,393,242,0"
                  ItemsSource="{Binding ControllerButtonOptions}" SelectedIndex="{Binding SelectedStartButtonIndex, Mode=TwoWay}">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding FunctionName}" TextTrimming="CharacterEllipsis" />
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>

        <!--Triggers-->
        <ComboBox x:Name="LTriggerComboBox" Width="110" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="85,83,0,0"
                  ItemsSource="{Binding ControllerTriggerOptions}" SelectedIndex="{Binding SelectedLTriggerIndex, Mode=TwoWay}"
                  IsEnabled="{Binding IsTriggerEnabled}">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding FunctionName}" Style="{StaticResource DisabledComboboxItemTextBlock}" />
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>
        <ComboBox x:Name="RTriggerComboBox" Width="110" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,83,45,0"
                  ItemsSource="{Binding ControllerTriggerOptions}" SelectedIndex="{Binding SelectedRTriggerIndex, Mode=TwoWay}"
                  IsEnabled="{Binding IsTriggerEnabled}">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding FunctionName}" Style="{StaticResource DisabledComboboxItemTextBlock}" />
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>

        <!--ThumbSticks-->
        <ComboBox x:Name="LStickComboBox" Width="110" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="85,203,0,0"
                  ItemsSource="{Binding ControllerLThumbStickOptions}" SelectedIndex="{Binding SelectedLStickIndex, Mode=TwoWay}">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding FunctionName}" />
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>
        <ComboBox x:Name="RStickComboBox" Width="110" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,372,40,0"
                  ItemsSource="{Binding ControllerRThumbStickOptions}" SelectedIndex="{Binding SelectedRStickIndex, Mode=TwoWay}">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding FunctionName}" />
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>

        <!--Restore Default Settings-->
        <Button x:Name="RestoreDefaultButton" Content="RESTORE DEFAULT" Width="141" Height="29"
                HorizontalAlignment="Center" VerticalAlignment="Bottom"
                Margin="0,0,0,37"
                BorderBrush="#FFFFC000" Background="#FFFFC000"
                FontFamily="Segoe UI Semibold" FontWeight="Bold" Foreground="#FF191919" FontSize="12.5"
                Command="{Binding RestoreDefault}" >
            <Button.Resources>
                <Style TargetType="{x:Type Border}">
                    <Setter Property="CornerRadius" Value="5"/>
                </Style>
            </Button.Resources>
        </Button>

        <!--Links-->
        <Button Click="LeftLink_Click" Height="35" Width="202"
                HorizontalAlignment="Left" VerticalAlignment="Bottom"
                Margin="0,0,0,21"
                Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" BorderThickness="0" />
        <Button Click="MiddleLink_Click" Height="22" Width="96"
                HorizontalAlignment="Center" VerticalAlignment="Bottom"
                Margin="336,0,337,15"
                Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" BorderThickness="0" />
        <Button Click="RightLink_Click" Height="33" Width="195"
                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Margin="0,0,17,19"
                Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" BorderThickness="0" />
    </Grid>
</Window>