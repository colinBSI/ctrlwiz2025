<Window x:Class="CtrlWiz.NW.UI.Views.HelpView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CtrlWiz.NW.UI.Views"
        xmlns:model="clr-namespace:CtrlWiz.NW.UI.ViewModels"
        mc:Ignorable="d"
        ResizeMode="NoResize"
        Topmost="True"
        WindowStartupLocation="CenterScreen"
        Title="Controller Map" Height="525" Width="775">
    <Window.Background>
        <ImageBrush>
            <ImageBrush.ImageSource>
                <BitmapImage UriSource="../Images/ControllerMap.png" />
            </ImageBrush.ImageSource>
        </ImageBrush>
    </Window.Background>

    <Window.DataContext>
        <model:HelpViewModel />
    </Window.DataContext>

    <Grid>
        <!--Buttons ComboBox-->
        <ComboBox x:Name="RBumberComboBox" Width="120" HorizontalAlignment="Right" VerticalAlignment="Top"  Margin="0,135,35,0" />
        <ComboBox x:Name="YButtonComboBox" Width="120" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,171,35,0" />
        <ComboBox x:Name="BButtonComboBox" Width="120" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,217,35,0" />
        <ComboBox x:Name="AButtonComboBox" Width="120" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,262,35,0" />
        <ComboBox x:Name="XButtonComboBox" Width="120" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,313,35,0" />
        <ComboBox x:Name="StartButtonComboBox" Width="120" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,393,242,0" />

        <!--Triggers ComboBox-->
        <ComboBox x:Name="LTriggerComboBox" Width="120" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="80,83,0,0" />
        <ComboBox x:Name="RTriggerComboBox" Width="120" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,83,35,0" />

        <!--ThumbSticks ComboBox-->
        <ComboBox x:Name="LStickComboBox" Width="120" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="80,203,0,0" />
        <ComboBox x:Name="RStickComboBox" Width="120" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,372,35,0" />

        <Button x:Name="RestoreDefaultButton" Content="RESTORE DEFAULT" Width="141" Height="29"
                HorizontalAlignment="Center" VerticalAlignment="Bottom"
                Margin="0,0,0,37"
                BorderBrush="#FFFFC000" Background="#FFFFC000"
                FontFamily="Segoe UI Semibold" FontWeight="Bold" Foreground="#FF343434" FontSize="11">
            <Button.Resources>
                <Style TargetType="{x:Type Border}">
                    <Setter Property="CornerRadius" Value="5"/>
                </Style>
            </Button.Resources>
        </Button>

        <!--Links-->
        <Button Click="LeftLink_Click" Height="35" Width="168"
                HorizontalAlignment="Left" VerticalAlignment="Bottom"
                Margin="0,0,0,21"
                Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" BorderThickness="0" />
        <Button Click="MiddleLink_Click" Height="22" Width="96"
                HorizontalAlignment="Center" VerticalAlignment="Bottom"
                Margin="336,0,337,15"
                Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" BorderThickness="0" />
        <Button Click="RightLink_Click" Height="33" Width="195"
                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Margin="0,0,17,19"
                Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" BorderThickness="0" />
    </Grid>
</Window>